# --- App ---
ENVIRONMENT=development
API_KEY=your-api-key-here
DEBUG=false
LOG_LEVEL=INFO

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dccm

# --- AWS Bedrock ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-2
BEDROCK_ANALYZER_MODEL=us.anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_DRAFTER_MODEL=us.anthropic.claude-sonnet-4-20250514-v1:0

# --- Microsoft 365 ---
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# --- Encryption ---
ENCRYPTION_KEY=your-fernet-key-here

# --- Scheduler ---
P1_SUMMARY_TIME=16:00
EMERGENT_WORK_INTERVAL_HOURS=2
TIMEZONE=Australia/Sydney

# --- Mailbox Config ---
MONITORED_MAILBOXES=staff1@dccm.com.au,staff2@dccm.com.au
EXCLUDED_MAILBOXES=accounts@dccm.com.au
INVOICE_FOLDER_NAME=Invoice Folder #1
MAINTENANCE_INBOX=maintenance@dccm.com.au

# --- Webhook ---
PUBLIC_WEBHOOK_BASE_URL=https://your-app.herokuapp.com

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000
