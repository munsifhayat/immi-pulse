# --- App ---
ENVIRONMENT=development
API_KEY=your-api-key-here              # generate: openssl rand -hex 32
DEBUG=false
LOG_LEVEL=INFO

# --- Database ---
# Heroku Postgres sets DATABASE_URL automatically (postgres:// scheme — auto-converted)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/immi_pulse

# --- Console JWT (multi-tenant Owner/Seat auth) ---
# REQUIRED for production. Generate: openssl rand -hex 64
JWT_SECRET=

# --- Password storage hardening ---
# Server-side pepper (HMAC-SHA256 key) applied before bcrypt. Keep OUT of the
# database — a DB-only leak with this absent yields hashes that are useless
# offline. REQUIRED for production. Generate: openssl rand -hex 64
# Rotate by setting a new value; existing users are upgraded silently on next login.
PASSWORD_PEPPER=
PASSWORD_BCRYPT_ROUNDS=12
# NIST SP 800-63B breach-list check via Pwned Passwords k-anonymity API.
# Only the first 5 chars of a SHA-1 leave the server; the password itself never does.
BREACH_CHECK_ENABLED=true
BREACH_CHECK_TIMEOUT_SECONDS=2.5

# --- Client Portal (legacy, separate session JWT) ---
PORTAL_SECRET_KEY=change-me-portal-secret-at-least-32-chars-long
PORTAL_SESSION_JWT_SECRET=change-me-session-jwt-secret-at-least-32-chars

# --- Encryption ---
ENCRYPTION_KEY=your-fernet-key-here    # generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# --- Frontend ---
FRONTEND_URL=https://app.immipulse.com  # used in invite + public form share links

# --- OpenAI (primary AI provider) ---
# REQUIRED for AI triage, document analysis, and email intake classification.
# Without this, those features fall back to a low-confidence heuristic.
OPENAI_API_KEY=
OPENAI_ANALYZER_MODEL=gpt-4o-mini
OPENAI_DRAFTER_MODEL=gpt-4o

# --- AWS (S3 only — Bedrock retired in favour of OpenAI) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-2

# --- Resend (transactional email) ---
RESEND_API_KEY=
# Resend's `onboarding@resend.dev` test sender ONLY delivers to the account
# owner's own verified email. For real client delivery, verify a domain at
# https://resend.com/domains then set a sender on that domain.
# Example after verifying theappscompany.ai:
#   RESEND_FROM_EMAIL=IMMI-PULSE <noreply@theappscompany.ai>
RESEND_FROM_EMAIL=IMMI-PULSE <onboarding@resend.dev>
RESEND_REPLY_TO=

# --- Microsoft 365 (optional, only for email integration) ---
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# --- Scheduler ---
P1_SUMMARY_TIME=16:00
EMERGENT_WORK_INTERVAL_HOURS=2
TIMEZONE=Australia/Sydney

# --- Mailbox Config (optional) ---
MONITORED_MAILBOXES=
EXCLUDED_MAILBOXES=
INVOICE_FOLDER_NAME=
MAINTENANCE_INBOX=

# --- Webhook ---
PUBLIC_WEBHOOK_BASE_URL=https://your-app.herokuapp.com

# --- CORS ---
# Comma-separated list of allowed origins (must include your production frontend URL)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://app.immipulse.com
